offset_top = 25.0
offset_right = 1133.0
offset_bottom = 638.0
text = "Es un día oscuro en la historia. El Imperio Faunus ha puesto sus miras en el planeta Calis en busca del todopoderoso artefacto \"Lupus,\" que se rumorea es una fuente de poder de escala infinita. Tu ciudad, la humilde DogTown, ha sido la encargada de resguardar las dos piezas que juntas forman el legendario artefacto. Tu misión, como el Escudero de Lupus, es obtener las dos piezas que conforman el artefacto y protegerlo del enemigo. Pero ten cuidado, no eres invencible. Un solo toque del enemigo es suficiente para acabar con tu mision.  Buena suerte."
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 1
clip_text = true

